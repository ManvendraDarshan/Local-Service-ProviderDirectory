{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Frontend",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"dev"
			],
			"options": {
				"cwd": "frontend"
			},
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Run Backend",
			"type": "shell",
			"command": ".\\venv\\Scripts\\python.exe -m uvicorn main:app --reload",
			"options": {
				"cwd": "backend"
			},
			"isBackground": true,
			"group": "build"
		}
	]
}